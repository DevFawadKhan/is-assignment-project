
enum Role {
    USER
    ADMIN
}
model User{
    id Int @id @default(autoincrement())
    name String
    email String @unique
    password String
    role Role @default(USER)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Bidirectional mapped relational integrity pointing toward authorized AES files inherently tracking ownership natively
    encryptedFiles EncryptedFile[]
}
